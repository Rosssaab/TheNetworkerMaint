# Copy to ".env" in the project root (load_dotenv in config.py loads it on startup).
# Admin maint app: use the same DATABASE_URL (and usually SECRET_KEY) as TheNetworkerDev.
# Do not commit a real .env file.

# Default dev port for this app (public site often uses 8103).
#PORT=8104

# Disable migration tombstone on the admin host.
# Tombstone for the *public* site only. Ignored when TNW_MAINT_APP=True (see tnw_feature_flags.py).
#TNW_MIGRATION_NOTICE=0

# Optional: log /dashboard phase timings to stderr (always on when Flask debug is on).
#TNW_DASHBOARD_TIMING=1

SECRET_KEY=dev-change-me

# Maint console sign-in (two operators; not stored in the users table).
TNW_MAINT_LOGIN_USER_1=admin1
TNW_MAINT_LOGIN_PASSWORD_1=change-me-one
TNW_MAINT_LOGIN_USER_2=admin2
TNW_MAINT_LOGIN_PASSWORD_2=change-me-two

# MariaDB / MySQL (site default). URL-encode special characters in the password (e.g. # -> %23).
# Create the DB user in MariaDB (not copied from SQL Server); then set USER/PASSWORD here.
DATABASE_URL=mysql+pymysql://USER:PASSWORD@localhost:3306/mynetworkermdb?charset=utf8mb4

# SQL Server (legacy; no longer used by the Flask app after migration to MariaDB)
#DATABASE_URL=mssql+pyodbc://localhost/TheNetworkerDev?driver=ODBC+Driver+17+for+SQL+Server&trusted_connection=yes

# Schema capture (scripts/capture_schema_ddl.py) — optional; defaults match backup_db.bat
#TNW_DDL_DATABASE_URL=mssql+pyodbc://TnwAdmin:PASSWORD@./SQLEXPRESS/MyNetworkerDev?driver=ODBC+Driver+17+for+SQL+Server
#TNW_DDL_SERVER=.\SQLEXPRESS
#TNW_DDL_DATABASE=MyNetworkerDev
#TNW_DDL_USER=TnwAdmin
#TNW_DDL_PASSWORD=

IDEAL_POSTCODES_API_KEY=
IDEAL_POSTCODES_API_ENDPOINT=https://api.ideal-postcodes.co.uk/v1

# UK /api/address-lookup (event wizard, dashboard): ideal (default; needs IDEAL_POSTCODES_API_KEY) or postcodesio (free, no key).
#TNW_ADDRESS_LOOKUP_PROVIDER=ideal
# Postcodes.io API root (no key). https://postcodes.io/
#TNW_POSTCODES_IO_BASE_URL=https://api.postcodes.io
# Overpass interpreter for premise-style addr:postcode (default: overpass-api.de).
#TNW_OVERPASS_INTERPRETER_URL=https://overpass-api.de/api/interpreter
# OSM policy: set a contact URL or app name (defaults from SITE_URL if set).
#TNW_NOMINATIM_USER_AGENT=MySite/1.0 (https://example.com/contact)
# Signed-in users only: enable /postcode-lookup-test (1/true/yes/on).
#TNW_ENABLE_POSTCODE_LOOKUP_TEST_PAGE=1
